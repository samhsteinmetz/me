# Frontend env (Vite). Copy to `.env.local` for dev; never commit `.env.local`.
# Only VITE_-prefixed vars are exposed to the client. No API keys/secrets live
# here — the frontend only knows the backend URL plus the public Firebase
# web config (safe to ship; access is enforced by Firebase + backend rules).
#
# These map to the brief's Create-React-App names (this project uses Vite):
#   REACT_APP_API_URL            -> VITE_API_URL
#   REACT_APP_FIREBASE_API_KEY   -> VITE_FIREBASE_API_KEY
#   REACT_APP_FIREBASE_AUTH_DOMAIN -> VITE_FIREBASE_AUTH_DOMAIN
#   REACT_APP_FIREBASE_PROJECT_ID  -> VITE_FIREBASE_PROJECT_ID
#   REACT_APP_FIREBASE_APP_ID      -> VITE_FIREBASE_APP_ID

# Base URL of the vitals backend (the Express app under /server).
# Local dev default is http://localhost:3001; set to your Heroku URL for prod.
VITE_API_URL=http://localhost:3001

# Firebase Web SDK config (Firebase Console → Project Settings → Your apps →
# Web app). Without these the vitals panel still renders all public data; only
# the "Log coffee now" button is hidden because there's no way to sign in.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
