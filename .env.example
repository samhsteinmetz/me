# Frontend env (Vite). Copy to `.env.local` for dev; never commit `.env.local`.
# Only VITE_-prefixed vars are exposed to the client, and only non-secret values
# belong here — the frontend just needs to know the backend URL.
#
# Production builds read `.env.production` (committed) which points VITE_API_URL
# at the deployed Render backend. Override locally via `.env.local`.

# Base URL of the vitals backend (the Express app under /server).
# Local dev default is http://localhost:3001.
VITE_API_URL=http://localhost:3001
