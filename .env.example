# Copy to `.env.local` for dev. Never commit `.env.local`.
# All Vite-side env vars must start with VITE_ to be exposed to the client.

# Base URL of the vitals backend (the Express app under `server/`).
# Local dev default:
VITE_API_BASE_URL=http://localhost:3001

# Firebase Web SDK config (Project Settings → Your apps → Web). Without
# these, the Vitals panel still renders public data; only the "Log Coffee"
# button is hidden because there's no way to sign in.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
