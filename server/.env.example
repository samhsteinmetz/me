# Copy this file to `.env` and fill in real values. Never commit the real `.env`.
# Any missing secret causes the backend to fall back to mock data for that
# endpoint and log a warning at startup. The frontend will still render.

# ---- Server ----
PORT=3001
# Comma-separated list of allowed frontend origins for CORS.
# Local dev + your GitHub Pages URL, for example:
CORS_ORIGIN=http://localhost:5173,https://samhsteinmetz.github.io

# Force every endpoint into mock-data mode regardless of which credentials
# are present. Useful for local UI work without configuring anything.
MOCK_DATA=false

# ---- Heroku Postgres ----
# Heroku injects this automatically when you attach the Heroku Postgres addon.
# Locally you can point at a docker postgres or your own instance.
DATABASE_URL=

# ---- Firebase Admin (server-side token verification) ----
# Generated from Firebase Console → Project Settings → Service Accounts →
# Generate new private key. Either paste the entire JSON as a single line,
# or set the three fields below. JSON wins if both are present.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Comma-separated list of email addresses allowed to POST coffee logs.
# Anyone signing in with Google outside this list gets a 403 on writes.
ALLOWED_EMAILS=samhsteinmetz@gmail.com

# ---- Fitbit Web API (OAuth 2.0) ----
# Create an app at dev.fitbit.com → Manage Your Apps. Use the
# "Personal" application type for single-user access.
# Generate a long-lived refresh token via the OAuth 2.0 tutorial:
# https://dev.fitbit.com/build/reference/web-api/troubleshooting-guide/oauth2-tutorial/
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REFRESH_TOKEN=

# ---- VIX data (RapidAPI / Yahoo Finance) ----
# Sign up at rapidapi.com, subscribe to a Yahoo Finance-style stock data API,
# and paste the key. The endpoint used by lib/vix.js is configurable.
RAPIDAPI_KEY=
RAPIDAPI_HOST=apidojo-yahoo-finance-v1.p.rapidapi.com
