# server/.env.example — copy to server/.env and fill in. Never commit .env.
#
# With NOTHING configured the server still runs: every endpoint returns
# deterministic mock data so the frontend renders end-to-end. Configure the
# real values below as you wire each integration up.

# Postgres connection string. Render/Heroku set this when you attach a Postgres
# add-on. Without it, coffee logs use an in-memory store.
DATABASE_URL=

# Google Health API (https://health.googleapis.com/v4) — OAuth 2.0.
# Create credentials in Google Cloud Console and add the redirect URI below.
GOOGLE_HEALTH_CLIENT_ID=        # OAuth 2.0 Client ID (…apps.googleusercontent.com)
GOOGLE_HEALTH_CLIENT_SECRET=    # OAuth 2.0 Client secret
GOOGLE_HEALTH_ACCESS_TOKEN=     # initial access token (auto-refreshes in memory)
GOOGLE_HEALTH_REFRESH_TOKEN=    # durable refresh token (from /auth/google flow)

# Must EXACTLY match the redirect URI registered in Google Cloud Console.
# If unset, it is derived from the incoming request host.
GOOGLE_HEALTH_REDIRECT_URI=https://mewebservice.onrender.com/auth/google/callback

# Firebase Admin — full service-account JSON pasted as a single-line string
# (Firebase Console → Project Settings → Service accounts → Generate new key).
# Used to verify the ID token sent by the frontend on POST /api/coffee.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Only these emails may POST coffee logs (comma-separated). Optional — leave
# blank to allow any signed-in Google user. Keeps the personal log single-user.
ALLOWED_EMAILS=samhsteinmetz@gmail.com

# Origins allowed to call this API (comma-separated, no wildcard). Add your
# local Vite origin here too if developing against this server, e.g.:
# ALLOWED_ORIGIN=https://samhsteinmetz.github.io,http://localhost:5173
ALLOWED_ORIGIN=https://samhsteinmetz.github.io

# Port. Render/Heroku set this automatically; defaults to 3001 locally.
PORT=3001

# Force every endpoint into mock-data mode regardless of credentials.
MOCK_DATA=false
